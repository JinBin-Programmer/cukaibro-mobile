# Copy this file to ".env" and fill in your CukaiBro Supabase project values.
# These are the SAME values as the web app's NEXT_PUBLIC_SUPABASE_* keys —
# pointing the mobile app at the same project is what makes the database shared.
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
